  <x:String x:Key="Settings.CustomDohHost">Eigener DoH-Host / URL</x:String>
  <x:String x:Key="Settings.CustomDohHostWatermark">cloudflare-dns.com oder https://dns.example:443</x:String>
  <x:String x:Key="Settings.CustomDohPath">Eigener DoH-Pfad</x:String>
  <x:String x:Key="Settings.CustomDohPathWatermark">/dns-query</x:String>
  <x:String x:Key="Settings.OnionDnsProxy">.onion-DNS &#252;ber Tor weiterleiten (Admin)</x:String>
  <x:String x:Key="Settings.OnionDnsProxyHint">Wenn aktiviert und als Administrator ausgef&#252;hrt, werden Windows-.onion-DNS-Anfragen &#252;ber Tor geleitet.</x:String>

  <x:String x:Key="Settings.TorAdvanced">Tor - Erweitert</x:String>
  <x:String x:Key="Settings.EntryNode">Einstiegsknoten (optional)</x:String>
  <x:String x:Key="Settings.EntryNodeHint">Einstiegsknoten k&#246;nnen nicht zusammen mit Bridges verwendet werden.</x:String>
  <x:String x:Key="Settings.IPv6Support">IPv6-Unterst&#252;tzung</x:String>
  <x:String x:Key="Settings.HardwareAccel">Hardwarebeschleunigung</x:String>
  <x:String x:Key="Settings.ConnectionPadding">Verbindungs-Padding</x:String>
  <x:String x:Key="Settings.OptionDefault">Standard</x:String>
  <x:String x:Key="Settings.OptionEnabled">Aktiviert</x:String>
  <x:String x:Key="Settings.OptionDisabled">Deaktiviert</x:String>
  <x:String x:Key="Settings.ConnectionPaddingAuto">Automatisch (empfohlen)</x:String>
  <x:String x:Key="Settings.MaxCircuitInactivity">Maximale Circuit-Inaktivit&#228;t (Minuten)</x:String>
  <x:String x:Key="Settings.RestrictedFirewallMode">Restriktiver Firewall-Modus</x:String>
  <x:String x:Key="Settings.AllowedPorts">Erlaubte Ports</x:String>
  <x:String x:Key="Settings.AllowedPortsWatermark">80,443</x:String>
  <x:String x:Key="Settings.EntryExitTip">Tipp: Einschr&#228;nkung von Ein-/Austrittsknoten kann Zuverl&#228;ssigkeit und Geschwindigkeit verringern.</x:String>

  <x:String x:Key="Settings.SplitTunnelingTitle">Split-Tunneling (Hybridmodus)</x:String>
  <x:String x:Key="Settings.SplitTunnelingHint">Im Hybridmodus kannst du w&#228;hlen, welche Apps Tor nutzen und welche direkt gehen. Ein Prozessname pro Zeile (z. B. chrome.exe).</x:String>
  <x:String x:Key="Settings.RouteAllWebTraffic">Gesamten Web-Traffic (Ports 80/443) &#252;ber Tor leiten</x:String>
  <x:String x:Key="Settings.BlockQuic">QUIC/UDP f&#252;r Tor-Apps blockieren (verhindert Umgehungs-Leaks)</x:String>
  <x:String x:Key="Settings.TorApps">Apps &#252;ber Tor (Hybridmodus)</x:String>
  <x:String x:Key="Settings.TorAppsWatermark">firefox.exe&#10;chrome.exe&#10;msedge.exe</x:String>
  <x:String x:Key="Settings.BypassApps">Apps, die Tor umgehen (optional)</x:String>
  <x:String x:Key="Settings.BypassAppsWatermark">steam.exe&#10;discord.exe</x:String>
  <x:String x:Key="Settings.SplitTunnelingEnableHint">Aktiviere TUN/VPN-Modus + Hybrid-Routing auf der Startseite, um Split-Tunneling zu nutzen.</x:String>

