<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="using:OnionHopV2.App.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="720"
             x:Class="OnionHopV2.App.Views.AboutPageView"
             x:DataType="vm:AboutPageViewModel">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="About"
                   FontSize="28"
                   FontWeight="SemiBold" />

        <suki:GlassCard Padding="20" CornerRadius="18">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Image Width="96"
                       Height="96"
                       Source="/Assets/logo.png" />
                <TextBlock Text="OnionHop V2"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="OnionHop V2.0.0"
                           Opacity="0.85"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </suki:GlassCard>

        <TextBlock Text="Links"
                   FontSize="16"
                   FontWeight="SemiBold" />

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Classes="Flat" Click="OnOpenReleasesClick">
                GitHub Issues
            </Button>
            <Button Classes="Flat" Click="OnOpenDiscordClick">
                Discord
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
